# =============================================================================
# Kwami LiveKit API - Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in your credentials:
#   cp .env.sample .env
#
# =============================================================================

# =============================================================================
# App Configuration
# =============================================================================
APP_ENV=development
DEBUG=true

# API Server
API_HOST=0.0.0.0
API_PORT=8080

# CORS (comma-separated origins, use * for development)
CORS_ORIGINS=http://localhost:5173,https://kwami.io

# Enable OpenAPI docs at /docs and /redoc in production (default: false)
# ENABLE_DOCS=true

# =============================================================================
# LiveKit Configuration (required for token generation)
# =============================================================================
# Get these from https://cloud.livekit.io/projects/YOUR_PROJECT/settings/keys

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# LiveKit SIP / telephony
# LIVEKIT_SIP_OUTBOUND_TRUNK_ID:
#   LiveKit outbound SIP trunk ID used for programmatic outbound calls.
# LIVEKIT_SIP_INBOUND_URI:
#   LiveKit SIP URI that Twilio dials for inbound calls, e.g.
#   sip:your-project.sip.livekit.cloud;transport=tcp
# LIVEKIT_SIP_DIAL_TRANSPORT:
#   Transport used when bridging calls into LiveKit SIP.
# LIVEKIT_SIP_PARTICIPANT_ATTRIBUTE_KEY:
#   Attribute key used to pass kwami identity through SIP participants.

LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
LIVEKIT_SIP_INBOUND_URI=
LIVEKIT_SIP_DIAL_TRANSPORT=tcp
LIVEKIT_SIP_PARTICIPANT_ATTRIBUTE_KEY=kwami_id

# Public API base URL used to build Twilio webhook endpoints.
# Example: https://api.kwami.io
APP_PUBLIC_URL=

# =============================================================================
# Twilio (required for phone number search/purchase and WhatsApp)
# =============================================================================
# Get these from https://console.twilio.com/
#
# TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN:
#   Core Twilio API credentials.
# TWILIO_PHONE_COUNTRY:
#   Default country used when searching or normalizing numbers.
# TWILIO_SIP_TRUNK_SID:
#   Twilio SIP trunk that purchased numbers are attached to.
# TWILIO_WHATSAPP_FROM:
#   Optional default WhatsApp sender in the form whatsapp:+14155550123
# TWILIO_VOICE_STATUS_CALLBACK_URL / TWILIO_MESSAGING_STATUS_CALLBACK_URL:
#   Optional explicit callback URLs. Leave blank to derive from APP_PUBLIC_URL.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_COUNTRY=US
TWILIO_SIP_TRUNK_SID=
TWILIO_WHATSAPP_FROM=
TWILIO_VOICE_STATUS_CALLBACK_URL=
TWILIO_MESSAGING_STATUS_CALLBACK_URL=

# =============================================================================
# Zep Cloud (required for memory endpoints)
# =============================================================================
# Get your API key:
#   1. Create account at https://app.getzep.com/
#   2. Go to Project Settings > API Keys
#   3. Create a new API key

ZEP_API_KEY=z_your-zep-api-key

# =============================================================================
# Supabase
# =============================================================================
# Get these from Supabase Dashboard: Project Settings > API Keys
#
# SUPABASE_URL: Project URL - used for JWKS auth token verification
# SUPABASE_SECRET_KEY: Secret API key (sb_secret_...) - admin DB access

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your-supabase-secret-key

# =============================================================================
# Stripe (required for credit purchases)
# =============================================================================
# Get these from https://dashboard.stripe.com/apikeys
# Webhook secret from https://dashboard.stripe.com/webhooks

STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# =============================================================================
# Kwami API Key (shared secret between agent and API)
# =============================================================================
# Used by the agent to report usage (X-API-Key header). Generate a random string.

KWAMI_API_KEY=your-random-kwami-api-key
